type RegisterCaveats struct {
  endpoint String
  proof    Link
}

type RegisterOk struct {}

type DeregisterCaveats struct {
  provider DID
}

type DeregisterOk struct {}

type ListCaveats struct {}

type Provider struct {
  ID DID (rename "id")
  endpoint String
  weight Int
  replicationWeight Int
}

type ListOk struct {
  providers [Provider]
}

type WeightSetCaveats struct {
  provider DID
  weight Int
  replicationWeight Int
}

type WeightSetOk struct {}
